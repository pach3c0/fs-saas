# .env da instância CANARY/BETA — copie para /var/www/cz-saas-beta/.env e preencha os segredos.
# (Os valores reais NUNCA vão pro git — este é só o template.)

# --- TRAVA DE AMBIENTE (o que torna o beta seguro) ---
APP_ENV=beta            # liga: e-mail suprimido + schedulers desligados (ver email.js / server.js)
NODE_ENV=production
PORT=3052

# --- BANCO ---
# Canary aponta para o MESMO banco de produção (testar com dados reais, isolado por org de teste).
# Use EXATAMENTE a mesma MONGODB_URI do .env de produção (/var/www/cz-saas/.env).
MONGODB_URI=__MESMA_DA_PRODUCAO__

# --- DOMÍNIO (espelha a estrutura multi-tenant no domínio beta) ---
BASE_DOMAIN=beta.cliquezoom.com.br
BASE_URL=https://beta.cliquezoom.com.br
OWNER_SLUG=__mesmo_da_producao__
OWNER_EMAIL=__mesmo_da_producao__

# --- SMTP (mantém as credenciais, mas o envio é SUPRIMIDO por APP_ENV=beta) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=__mesmo_da_producao__
SMTP_PASS=__mesmo_da_producao__

# --- SEGREDOS (iguais aos da produção) ---
JWT_SECRET=__mesmo_da_producao__
PLATFORM_ADMIN_KEY=__mesmo_da_producao__

# --- RHYNO / SSO (Gestão) ---
# Em beta, aponte para um tenant de TESTE do Rhyno (não o tenant 2 da Flávia), ou deixe em branco
# para a aba Gestão ficar inerte no beta. Ver memória project_rhyno_tenant_leak_fix.
SSO_SHARED_SECRET=
RHYNO_BASE_URL=
RHYNO_API_URL=
RHYNO_POC_EMAIL=
