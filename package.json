{
  "name": "fs-saas",
  "version": "1.0.0",
  "description": "Plataforma SaaS para fotografos: portfolio, selecao de fotos e entrega online",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:css": "npx @tailwindcss/cli -i ./assets/css/tailwind-input.css -o ./assets/css/tailwind.css --minify",
    "deploy": "npm run build:css",
    "test": "npx playwright test",
    "test:local": "npx playwright test --config=playwright.local.config.js",
    "test:local:report": "npx playwright show-report playwright-report-local",
    "test:smoke": "npx playwright test --config=playwright.smoke.config.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.74",
    "ai": "^6.0.209",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.0",
    "mercadopago": "^2.12.0",
    "mongoose": "^9.1.5",
    "multer": "^2.0.0",
    "nodemailer": "^8.0.1",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.1.18",
    "nodemon": "^3.0.2",
    "tailwindcss": "^4.1.18"
  },
  "keywords": [
    "fotografia",
    "portfolio",
    "admin",
    "galeria"
  ],
  "author": "FS FOTOGRAFIAS",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": "22.x"
  }
}
