PORT=3051
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/fssaas
JWT_SECRET=your-secret-here
BASE_DOMAIN=cliquezoom.com.br
OWNER_SLUG=seu-slug-aqui
OWNER_EMAIL=seu@email.com
# Contas protegidas: NUNCA rebaixadas/suspensas automaticamente (estorno/chargeback/carência).
# OBRIGATÓRIO setar quando MP_USE_PREAPPROVAL=true (senão a reversão por estorno pode rebaixar
# uma conta real). Slugs separados por vírgula.
PROTECTED_ORG_SLUGS=slug1,slug2
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_USER=seu@email.com
SMTP_PASS=sua-senha

# Chave de proteção para editar o template padrão da plataforma
PLATFORM_ADMIN_KEY=sua-chave-secreta-aqui

# Stripe (opcional para desenvolvimento)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Mercado Pago (gateway ativo). Public Key é pública (browser); Access Token e Webhook Secret são
# SEGREDOS — só no servidor. MP_USE_PREAPPROVAL=true liga a cobrança (PreApproval avulsa + CardForm).
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...   (secreto, ~75 chars)
# MERCADOPAGO_PUBLIC_KEY=APP_USR-...     (público, ~44 chars)
# MP_WEBHOOK_SECRET=...                  (secreto — valida HMAC do webhook)
# MP_USE_PREAPPROVAL=true                (exige PROTECTED_ORG_SLUGS setado)
